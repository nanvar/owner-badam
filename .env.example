DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Web Push (VAPID) — generate with: node scripts/generate-vapid-keys.mjs
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@badam.ae"

# Cron — pass as ?secret=... or Authorization: Bearer <value> when
# calling /api/cron/daily. Also unlocks the same payload from the
# first admin request of each UTC day, so cron failures self-heal.
CRON_SECRET="generate-with-openssl-rand-hex-32"

# S3 / MinIO file storage — point at s3.badam.ae for prod, MinIO for dev.
S3_ENDPOINT="https://s3.badam.ae"
S3_REGION="us-east-1"
S3_BUCKET="badam"
S3_ACCESS_KEY="minio-access-key"
S3_SECRET_KEY="minio-secret-key"
# Force path-style addressing (https://s3.badam.ae/bucket/key) — MinIO needs it.
S3_FORCE_PATH_STYLE="true"
# Public URL prefix that fronts the same files (CDN or the same endpoint).
S3_PUBLIC_URL="https://s3.badam.ae/badam"
