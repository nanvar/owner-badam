DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# S3 / MinIO file storage — point at s3.badam.ae for prod, MinIO for dev.
S3_ENDPOINT="https://s3.badam.ae"
S3_REGION="us-east-1"
S3_BUCKET="badam"
S3_ACCESS_KEY="minio-access-key"
S3_SECRET_KEY="minio-secret-key"
# Force path-style addressing (https://s3.badam.ae/bucket/key) — MinIO needs it.
S3_FORCE_PATH_STYLE="true"
# Public URL prefix that fronts the same files (CDN or the same endpoint).
S3_PUBLIC_URL="https://s3.badam.ae/badam"
