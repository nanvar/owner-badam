generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  OWNER
  SUPERADMIN
}

enum DirectBookingStatus {
  PENDING       // Submitted from the website, awaiting payment
  PAID          // Payment confirmed (via Strapi)
  CANCELLED     // Guest or admin cancelled
  COMPLETED     // Stay finished
}

enum CompanyExpenseCategory {
  SALARY
  RENT
  MARKETING
  SOFTWARE
  TRAVEL
  TAX
  UTILITIES
  OTHER
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(OWNER)
  locale    String   @default("en")
  blocked   Boolean  @default(false)
  // Owner profile (used as Recipient in settlements)
  phone     String?
  taxId     String?  // e.g. TC765777558
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  properties Property[] @relation("OwnerProperties")

  // Settlement history: payments made to this user as an owner.
  receivedPayments OwnerPayment[] @relation("OwnerPaymentRecipient")
  // Audit trail: payments this user (as admin) recorded for someone else.
  recordedPayments OwnerPayment[] @relation("OwnerPaymentRecorder")
  ownerReports     OwnerReport[]  @relation("OwnerReportRecipient")
  createdReports   OwnerReport[]  @relation("OwnerReportCreator")
  devices          OwnerDevice[]
  debts            OwnerDebt[]    @relation("OwnerDebts")
  preferences      UserPreference?
  webPushSubs      WebPushSubscription[]
  activities       ActivityEvent[]
  uploadedMedia    PropertyMedia[]    @relation("MediaUploader")
  createdEvents    PropertyEvent[]    @relation("EventCreator")
  stayRequests     OwnerReservationRequest[] @relation("RequestOwner")
  decidedRequests  OwnerReservationRequest[] @relation("RequestDecider")
}

model Property {
  id            String    @id @default(cuid())
  name          String
  address       String?   @db.Text
  airbnbIcalUrl String?   @db.Text
  airbnbUrl     String?   @db.Text
  basePrice     Float     @default(0)
  cleaningFee   Float     @default(0)
  color         String    @default("#3b82f6")
  notes         String?   @db.Text
  // Listing details — populated by the Airbnb crawler.
  description   String?   @db.Text
  bedrooms      Int?
  bathrooms     Float?
  beds          Int?
  maxGuests     Int?
  amenities     Json?
  photos        Json?
  crawledAt     DateTime?
  crawlPayload  Json?
  // When true the property is only being managed for the owner — no
  // rentals expected. Affects dashboards (no revenue KPIs) and unlocks
  // the owner's "stay quota + service charge" workflow.
  managementOnly Boolean   @default(false)
  // Optional admin-uploaded cover photo (S3 URL) used when the Airbnb
  // photo array is empty (typical for managementOnly properties).
  coverPhotoUrl String?   @db.Text
  ownerId       String
  owner         User      @relation("OwnerProperties", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastSyncedAt  DateTime?

  reservations   Reservation[]
  expenses       Expense[]
  advances       Advance[]
  directBookings DirectBooking[]
  ownerPayments  OwnerPayment[]
  companyEntries CompanyExpense[]
  ownerReports   OwnerReport[]
  projection     PropertyProjection?
  investmentSpends Investment[]
  ownerDebts     OwnerDebt[]
  media            PropertyMedia[]
  events           PropertyEvent[]
  serviceCharge    ServiceChargeSchedule?
  serviceInstances ServiceChargeInstance[]
  stayQuota        OwnerStayQuota?
  stayRequests     OwnerReservationRequest[]

  @@index([ownerId])
  @@index([managementOnly])
}

// One-shot pitch deck for prospective owners. Captures every dynamic
// figure shown on the financial-projection slides so the admin can edit
// once and re-export as PDF or PPTX. The non-dynamic copy (services
// bullets, "about us" paragraph) is sourced from settings/defaults and
// optionally overridden per-property via the text columns below.
model PropertyProjection {
  id                       String   @id @default(cuid())
  propertyId               String   @unique
  property                 Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  // Hero descriptors — Property model already carries `bedrooms`,
  // these are free-text labels for the slide.
  area                     String   @default("")
  buildingName             String   @default("")

  // Hero average — the headline "You could earn X net per month".
  avgMonthlyNet            Float    @default(0)

  // Recurring costs.
  duMonthly                Float    @default(380)
  dewaChillerMonthly       Float    @default(650)
  propertyInsuranceYearly  Float    @default(1200)
  maintenanceMonthly       Float    @default(125)
  dtcmPermitYearly         Float    @default(370)

  // Fee structure.
  managementFeePct         Float    @default(20)
  vatPct                   Float    @default(5)
  portalFeePct             Float    @default(10.5)

  // Pessimistic / Realistic / Optimistic scenarios.
  pessimisticOccupancy     Float    @default(75)
  realisticOccupancy       Float    @default(80)
  optimisticOccupancy      Float    @default(85)
  // Net annual revenue (after all expenses) is admin-entered — the
  // deck derives gross + expense breakdown from this. DB columns are
  // historically named *Gross; @map preserves the column name.
  pessimisticNet           Float    @default(0) @map("pessimisticGross")
  realisticNet             Float    @default(0) @map("realisticGross")
  optimisticNet            Float    @default(0) @map("optimisticGross")

  // Optional overrides for the static copy. Newline-separated bullets.
  listingMgmtBullets       String?  @db.Text
  guestMgmtBullets         String?  @db.Text
  propertyMgmtBullets      String?  @db.Text
  aboutText                String?  @db.Text

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model Reservation {
  id                String            @id @default(cuid())
  propertyId        String
  property          Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  externalId        String
  source            String            @default("airbnb")
  status            ReservationStatus @default(CONFIRMED)
  guestName         String?
  guestPhone        String?
  guestEmail        String?
  numGuests         Int?
  checkIn           DateTime
  checkOut          DateTime
  nights            Int
  pricePerNight     Float             @default(0)
  totalPrice        Float             @default(0) // gross amount paid by guest
  agencyCommission  Float             @default(0) // PMS fee
  portalCommission  Float             @default(0) // Airbnb / Booking commission
  cleaningFee       Float             @default(0)
  serviceFee        Float             @default(0) // legacy / misc service fee
  taxes             Float             @default(0)
  payout            Float             @default(0) // amount paid to owner
  currency          String            @default("AED")
  notes             String?           @db.Text
  rawSummary        String?           @db.Text
  rawDescription    String?           @db.Text
  detailsFilled     Boolean           @default(false)
  // When true, the booking is in the future / not yet paid. The company
  // dashboard accounts these separately so management can see realized
  // revenue vs pipeline. Owner reports ignore this flag.
  upcoming          Boolean           @default(false)
  // Whether the guest has fully paid for this reservation. Extensions
  // (when iCal lengthens an existing stay) carry their own `paid` flag
  // on the ReservationExtension row.
  paid              Boolean           @default(false)
  // Once a reservation is bundled into an owner report it's "closed" and
  // no longer appears in the report builder's pickable list.
  reportId          String?
  report            OwnerReport?      @relation(fields: [reportId], references: [id], onDelete: SetNull)
  // Billing month "YYYY-MM" the row belongs to for monthly reporting.
  // Defaults to the checkIn month; admins can flip the form's
  // "Next month" checkbox to roll the row into the following month.
  monthKey          String?           @db.VarChar(7)
  syncedAt          DateTime          @default(now())
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  extensions        ReservationExtension[]

  @@unique([propertyId, externalId])
  @@index([propertyId])
  @@index([checkIn])
  @@index([checkOut])
  @@index([reportId])
  @@index([monthKey])
  @@index([paid])
}

// Stay extensions captured from iCal — when Airbnb pushes a longer
// checkOut for a reservation we already track, we leave the original
// reservation alone and record the extra nights here so reports keep
// the original window separate from the add-on. Admins fill in
// price / commissions / paid flag the same way as a reservation.
model ReservationExtension {
  id               String      @id @default(cuid())
  reservationId    String
  reservation      Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  // The added window. checkIn typically equals the previous checkOut.
  checkIn          DateTime
  checkOut         DateTime
  nights           Int
  totalPrice       Float       @default(0)
  agencyCommission Float       @default(0)
  portalCommission Float       @default(0)
  payout           Float       @default(0)
  currency         String      @default("AED")
  notes            String?     @db.Text
  paid             Boolean     @default(false)
  // Billing month — admins flip this to the next month if the extension
  // hasn't been paid by the time the original reservation's owner
  // report is generated.
  monthKey         String?     @db.VarChar(7)
  detailsFilled    Boolean     @default(false)
  // Same bundling pattern as Reservation/Expense — once attached to an
  // owner report the extension is "closed" and not offered to the
  // builder again. Useful when the parent reservation went into a
  // different month's report than the extension itself.
  reportId         String?
  report           OwnerReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([reservationId])
  @@index([monthKey])
  @@index([paid])
  @@index([reportId])
}

enum ExpenseType {
  DEWA
  CHILLER
  DU
  GAS
  CLEANING
  DTCM
  SERVICE_CHARGE
  OTHERS
}

model Expense {
  id          String      @id @default(cuid())
  propertyId  String
  property    Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  date        DateTime
  type        ExpenseType
  description String      @db.Text
  amount      Float       // positive — represented as a deduction in reports
  reportId    String?
  report      OwnerReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)
  // Billing month "YYYY-MM" the expense belongs to. Defaults to the
  // expense date's month; admins can flip "Next month" in the form.
  monthKey    String?     @db.VarChar(7)
  // When true the company paid for this expense out of invested
  // capital. Triggers two side-effects on create:
  //   1) an Investment SPEND row is auto-recorded
  //   2) an OwnerDebt row is created against the property's owner
  // The expense itself still appears in the owner's report so they
  // see what was spent on the property.
  paidFromCompanyInvest Boolean @default(false)
  investmentSpend       Investment?     @relation("ExpenseInvestmentSpend")
  ownerDebt             OwnerDebt?      @relation("ExpenseOwnerDebt")
  // Receipt / proof attachment (S3-hosted). Required by the form on
  // every new expense — admins must upload a photo or PDF so the
  // owner can verify spend.
  receiptMediaId String?
  receiptMedia   PropertyMedia? @relation("ExpenseReceipt", fields: [receiptMediaId], references: [id], onDelete: SetNull)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([propertyId])
  @@index([date])
  @@index([reportId])
  @@index([monthKey])
  @@index([paidFromCompanyInvest])
}

model Advance {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  date        DateTime
  concept     String   // e.g. "Payment for Rental"
  amount      Float    // positive — represented as a deduction in reports
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([propertyId])
  @@index([date])
}

// Direct bookings come from the public site. Kept separate from `Reservation`
// (which is populated by the Airbnb iCal sync) so the two channels don't
// pollute each other. The Strapi payment flow writes here on success.
model DirectBooking {
  id              String              @id @default(cuid())
  propertyId      String
  property        Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  guestName       String
  guestEmail      String
  guestPhone      String?
  numGuests       Int
  checkIn         DateTime
  checkOut        DateTime
  nights          Int
  pricePerNight   Float               @default(0)
  cleaningFee     Float               @default(0)
  totalPrice      Float               @default(0)
  currency        String              @default("AED")
  status          DirectBookingStatus @default(PENDING)
  // Payment integration — populated by Strapi callback / webhook.
  paymentRef      String?
  paymentProvider String?
  paidAt          DateTime?
  paidAmount      Float?
  notes           String?             @db.Text
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([propertyId])
  @@index([checkIn])
  @@index([status])
}

enum CompanyTransactionKind {
  EXPENSE
  PROFIT
  // DEPOSIT entries are pure log rows — they don't feed dashboard / report
  // totals. Each can later be marked refunded, at which point
  // `refundedAt` / `refundedAmount` are populated.
  DEPOSIT
}

// CompanyExpense holds expense, per-property profit, and per-property
// deposit log entries — the `kind` discriminator picks between them.
// PROFIT/DEPOSIT entries reference a property; EXPENSE entries use a
// category. They share a date+amount shape so the dashboard can net them.
model CompanyExpense {
  id              String                  @id @default(cuid())
  kind            CompanyTransactionKind  @default(EXPENSE)
  // EXPENSE only — null for PROFIT/DEPOSIT entries
  category        CompanyExpenseCategory?
  // PROFIT/DEPOSIT only — null for EXPENSE entries
  propertyId      String?
  property        Property?               @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  date            DateTime
  description     String                  @db.Text
  amount          Float
  // DEPOSIT-only refund metadata. When refundedAt is null the deposit is
  // still held; populated values mean the company has paid it back.
  refundedAt      DateTime?
  refundedAmount  Float?
  // Billing month "YYYY-MM" — used for monthly company-finance reports.
  // Same convention as Reservation/Expense: defaults to the entry date,
  // bumped by one month when the form's "Next month" checkbox is on.
  monthKey        String?                 @db.VarChar(7)
  // PROFIT rows can be entered before the cash actually arrives. Only
  // paid profits feed the dashboard's company KPIs. EXPENSE/DEPOSIT
  // entries don't expose the toggle and keep the default `true`.
  paid            Boolean                 @default(true)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([date])
  @@index([kind])
  @@index([propertyId])
  @@index([monthKey])
}

// Ledger of investor capital flowing into and out of the company.
// INCOME rows record money received from investors; SPEND rows
// record money paid out of that pool — typically auto-created when
// a property expense is marked "paid from company invest". Purely
// informational on the dashboard, never folded into the P&L math.
enum InvestmentKind {
  INCOME
  SPEND
}

model Investment {
  id          String         @id @default(cuid())
  kind        InvestmentKind @default(INCOME)
  amount      Float
  source      String         @db.VarChar(255)
  description String?        @db.Text
  date        DateTime
  // Optional linkage when a SPEND row was auto-created from a
  // property expense — keeps an audit trail in both directions.
  propertyId  String?
  property    Property?      @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  expenseId   String?        @unique
  expense     Expense?       @relation("ExpenseInvestmentSpend", fields: [expenseId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([kind])
  @@index([propertyId])
  @@index([date])
}

// Pending / settled IOUs owed by owners to the company. Created
// automatically when an owner's expense is paid from invested
// capital — the owner now owes the company that amount. Admin flips
// the row to PAID once the owner reimburses.
enum DebtStatus {
  PENDING
  PAID
}

model OwnerDebt {
  id          String     @id @default(cuid())
  ownerId     String
  owner       User       @relation("OwnerDebts", fields: [ownerId], references: [id], onDelete: Cascade)
  propertyId  String?
  property    Property?  @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  expenseId   String?    @unique
  expense     Expense?   @relation("ExpenseOwnerDebt", fields: [expenseId], references: [id], onDelete: Cascade)
  amount      Float
  description String?    @db.Text
  status      DebtStatus @default(PENDING)
  paidAt      DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([ownerId])
  @@index([status])
  @@index([propertyId])
}

// A curated bundle of one property's reservations + expenses, prepared by
// admin for an owner. Once an item belongs to a report it's "closed" and
// no longer offered when building future reports.
model OwnerReport {
  id            String   @id @default(cuid())
  ownerId       String
  owner         User     @relation("OwnerReportRecipient", fields: [ownerId], references: [id], onDelete: Cascade)
  propertyId    String
  property      Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name          String   // e.g. "March 2026"
  notes         String?  @db.Text
  // Snapshots of the totals at creation time — kept on the row so the
  // report stays stable even if items are later edited.
  totalIncome   Float    @default(0)
  totalExpenses Float    @default(0)
  netPayout     Float    @default(0)
  // Settlement state — set when management records the corresponding
  // OwnerPayment via `payReportAction`. paidMethod is free-form short
  // ("cash", "bank_transfer", "card"), paidReference is the external
  // receipt / transfer id if provided.
  paidAt        DateTime?
  paidMethod    String?  @db.VarChar(32)
  paidReference String?  @db.VarChar(120)
  createdById   String?
  createdBy     User?    @relation("OwnerReportCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reservations  Reservation[]
  expenses      Expense[]
  extensions    ReservationExtension[]
  payments      OwnerPayment[]

  @@index([ownerId])
  @@index([propertyId])
  @@index([paidAt])
}

// Cash settlements paid to an owner. The dashboard sums these as
// "Owners amount" — i.e. how much the company has actually disbursed,
// not the accrued reservation `payout` figure. recordedById tracks who
// entered the row so management has an audit trail.
model OwnerPayment {
  id           String    @id @default(cuid())
  ownerId      String
  owner        User      @relation("OwnerPaymentRecipient", fields: [ownerId], references: [id], onDelete: Cascade)
  // Optional: which property the payout covers. Helps admins reconcile
  // when an owner has multiple properties. Null means the payment is
  // owner-wide (legacy / cross-property settlement).
  propertyId   String?
  property     Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  date         DateTime
  amount       Float
  method       String?   // bank, cash, transfer, …
  reference    String?   // invoice / period / external ref
  notes        String?   @db.Text
  // Explicit billing month (YYYY-MM) — selected by the admin so reports
  // attribute the payout to the period it settles, separate from the
  // cash-out date stored above.
  monthKey     String?   @db.VarChar(7)
  // Set when this payment was created by `payReportAction` — links the
  // cash-out row back to the report it settles so the reports list can
  // surface paid state without a separate join.
  reportId     String?
  report       OwnerReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)
  recordedById String?
  recordedBy   User?     @relation("OwnerPaymentRecorder", fields: [recordedById], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([ownerId])
  @@index([propertyId])
  @@index([date])
  @@index([monthKey])
  @@index([reportId])
}

// Push-notification device tokens for the owner mobile app. One owner
// can have several devices; the same Expo push token never repeats so
// it's the unique key — re-registrations bump `updatedAt`.
model OwnerDevice {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String?  // ios / android (best-effort, app reports it)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model AppSettings {
  id          Int      @id @default(1)
  brandName   String   @default("Badam Owners")
  legalName   String   @default("Badam Holiday Homes")
  tagline     String   @default("Curated short-term rentals across Dubai.")
  logoUrl     String?  @db.Text
  faviconUrl  String?  @db.Text
  email       String?
  phone       String?
  whatsapp    String?
  website     String?  @db.Text
  address     String?  @db.Text
  city        String?
  country     String?
  instagram   String?  @db.Text
  facebook    String?  @db.Text
  linkedin    String?  @db.Text
  tiktok      String?  @db.Text
  youtube     String?  @db.Text
  bookingUrl  String?  @db.Text
  ownerPortal String?  @db.Text
  about       String?  @db.Text
  currency    String   @default("AED")
  timezone    String   @default("Asia/Dubai")
  updatedAt   DateTime @updatedAt
}

// ============================================================
// Foundation models for property docs/history, owner activity,
// service charge tracking, owner stay quota + booking requests,
// and per-user notification/UI preferences.
// ============================================================

// Universal media row attached to a property. The `kind` discriminates
// gallery photos, official documents (contracts, deeds, NOC), receipt
// attachments for expenses, and per-event photos.
enum PropertyMediaKind {
  PHOTO
  DOCUMENT
  RECEIPT
  EVENT_PHOTO
  SERVICE_CHARGE_PROOF
  COVER
}

model PropertyMedia {
  id           String            @id @default(cuid())
  propertyId   String
  property     Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  kind         PropertyMediaKind
  // Public S3 URL. The form uploads via presigned PUT then stores the
  // returned canonical URL here. Original filename + size + mime kept
  // for download UX.
  url          String            @db.Text
  fileName     String?           @db.VarChar(255)
  fileSize     Int?
  mimeType     String?           @db.VarChar(120)
  title        String?           @db.VarChar(255)
  caption      String?           @db.Text
  takenAt      DateTime?
  uploadedById String?
  uploadedBy   User?             @relation("MediaUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  // Reverse FK populated when this row is referenced by an Expense as
  // a receipt — lets us prevent deletion mid-flight.
  expenseReceipts Expense[]      @relation("ExpenseReceipt")
  eventId      String?
  event        PropertyEvent?    @relation(fields: [eventId], references: [id], onDelete: SetNull)
  serviceInstanceId String?
  serviceInstance   ServiceChargeInstance? @relation(fields: [serviceInstanceId], references: [id], onDelete: SetNull)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([propertyId, kind])
  @@index([eventId])
  @@index([serviceInstanceId])
}

// Timeline entry on a property — admin notes about renovations,
// inspections, condition changes, etc. Owner sees these in the
// property history tab.
model PropertyEvent {
  id          String          @id @default(cuid())
  propertyId  String
  property    Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  kind        String          @db.VarChar(40) // free-form tag: RENOVATION / INSPECTION / FURNISHING / ISSUE / NOTE …
  title       String          @db.VarChar(255)
  description String?         @db.Text
  happenedAt  DateTime
  createdById String?
  createdBy   User?           @relation("EventCreator", fields: [createdById], references: [id], onDelete: SetNull)
  media       PropertyMedia[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([propertyId])
  @@index([happenedAt])
}

// Service charge configuration: per-property quarterly (or custom)
// bill that the building/developer emails directly to the owner.
// PMS only nags the owner to check email + lets admin file proof.
model ServiceChargeSchedule {
  id                 String   @id @default(cuid())
  propertyId         String   @unique
  property           Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  // Months between bills (3 = quarterly, 6 = semi-annual, 12 = annual).
  frequencyMonths    Int      @default(3)
  // How many days before dueDate the daily reminder starts.
  reminderDaysBefore Int      @default(7)
  // First-cycle anchor; subsequent instances are computed from this.
  firstDueDate       DateTime
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

enum ServiceChargeStatus {
  UPCOMING
  REMINDING
  PAID
  SKIPPED
}

model ServiceChargeInstance {
  id           String              @id @default(cuid())
  propertyId   String
  property     Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  dueDate      DateTime
  status       ServiceChargeStatus @default(UPCOMING)
  paidAt       DateTime?
  amount       Float?              // optional — admin can record after payment
  notes        String?             @db.Text
  // Last day daily reminders were sent (so the cron doesn't double-fire).
  lastReminderAt DateTime?
  proofs       PropertyMedia[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@unique([propertyId, dueDate])
  @@index([status])
  @@index([dueDate])
}

// Per-property cap on how many days per year the owner may stay in
// the unit themselves. Used to validate OwnerReservationRequest rows.
model OwnerStayQuota {
  id          String   @id @default(cuid())
  propertyId  String   @unique
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  daysPerYear Int      @default(0)
  // Month-day anchor for the yearly cycle (1=January, 12=December).
  // Defaults to Jan 1.
  yearStartMonth Int   @default(1)
  yearStartDay   Int   @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum StayRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model OwnerReservationRequest {
  id         String            @id @default(cuid())
  propertyId String
  property   Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  ownerId    String
  owner      User              @relation("RequestOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  checkIn    DateTime
  checkOut   DateTime
  nights     Int
  notes      String?           @db.Text
  status     StayRequestStatus @default(PENDING)
  decidedAt  DateTime?
  decidedById String?
  decidedBy  User?             @relation("RequestDecider", fields: [decidedById], references: [id], onDelete: SetNull)
  decisionNote String?         @db.Text
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([propertyId])
  @@index([ownerId])
  @@index([status])
  @@index([checkIn])
}

// Owner-facing notification / activity feed. One row per noteworthy
// thing that happened that the owner might care about.
model ActivityEvent {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  // Stable enum-style tag — see NotificationType in code for the full
  // set. Stored as String so we don't need a schema migration when
  // adding new categories.
  type      String   @db.VarChar(60)
  title     String   @db.VarChar(255)
  body      String?  @db.Text
  // Anything the UI might want — propertyId, expenseId, amount, etc.
  data      Json?
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([ownerId, createdAt])
  @@index([ownerId, readAt])
  @@index([type])
}

// Free-form per-user prefs. JSON keeps it open-ended so future
// preference flags don't require schema migrations.
model UserPreference {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Strip the dashboard down to a single hero card for owners who
  // just want to glance at their income.
  easyMode          Boolean  @default(false)
  // Per-notification-category opt-in/out. Keys are NotificationType
  // values. Missing keys default to ENABLED.
  notificationPrefs Json?
  // Reserved for future UI prefs (theme, locale override, etc.).
  ui                Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Cron / on-demand daily-job execution log. The unique (jobKey,
// runDate) constraint guarantees a job runs at most once per day no
// matter how many triggers fire — cron + first admin login + manual
// retry can all call runDailyJobs() and only the first wins.
model DailyJobRun {
  id         String    @id @default(cuid())
  jobKey     String    @db.VarChar(60)
  runDate    String    @db.VarChar(10) // "YYYY-MM-DD" — admin-local day key
  trigger    String    @db.VarChar(20) // "cron" / "admin-login" / "manual"
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  result     Json?
  error      String?   @db.Text

  @@unique([jobKey, runDate])
  @@index([runDate])
}

// VAPID-based Web Push subscription. Mirrors PushManager.subscribe
// output. One row per device/browser per user.
model WebPushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Push endpoints fit in 500 chars in practice; we cap so MySQL can
  // index it. p256dh + auth are smaller fixed-size base64 strings.
  endpoint  String   @unique(length: 500) @db.VarChar(500)
  p256dh    String   @db.VarChar(255)
  auth      String   @db.VarChar(120)
  userAgent String?  @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Single-row table holding the active SMTP configuration. Stored in
// DB (not env) so admins can update it from settings without redeploy.
// Password is plain-text — protect this row at the application layer.
model MailConfig {
  id          String   @id @default(cuid())
  // Singleton: every row has `key="default"` and the action upserts on
  // that key so we always have at most one config row.
  key         String   @unique @db.VarChar(40)
  host        String   @db.VarChar(255)
  port        Int      @default(587)
  secure      Boolean  @default(false)
  username    String?  @db.VarChar(255)
  password    String?  @db.VarChar(255)
  fromEmail   String   @db.VarChar(255)
  fromName    String?  @db.VarChar(120)
  replyTo     String?  @db.VarChar(255)
  enabled     Boolean  @default(true)
  lastTestAt  DateTime?
  lastTestOk  Boolean?
  lastTestErr String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
