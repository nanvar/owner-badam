generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  OWNER
  SUPERADMIN
}

enum DirectBookingStatus {
  PENDING       // Submitted from the website, awaiting payment
  PAID          // Payment confirmed (via Strapi)
  CANCELLED     // Guest or admin cancelled
  COMPLETED     // Stay finished
}

enum CompanyExpenseCategory {
  SALARY
  RENT
  MARKETING
  SOFTWARE
  TRAVEL
  TAX
  UTILITIES
  OTHER
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(OWNER)
  locale    String   @default("en")
  blocked   Boolean  @default(false)
  // Owner profile (used as Recipient in settlements)
  phone     String?
  taxId     String?  // e.g. TC765777558
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  properties Property[] @relation("OwnerProperties")

  // Settlement history: payments made to this user as an owner.
  receivedPayments OwnerPayment[] @relation("OwnerPaymentRecipient")
  // Audit trail: payments this user (as admin) recorded for someone else.
  recordedPayments OwnerPayment[] @relation("OwnerPaymentRecorder")
  ownerReports     OwnerReport[]  @relation("OwnerReportRecipient")
  createdReports   OwnerReport[]  @relation("OwnerReportCreator")
  devices          OwnerDevice[]
}

model Property {
  id            String    @id @default(cuid())
  name          String
  address       String?   @db.Text
  airbnbIcalUrl String?   @db.Text
  airbnbUrl     String?   @db.Text
  basePrice     Float     @default(0)
  cleaningFee   Float     @default(0)
  color         String    @default("#3b82f6")
  notes         String?   @db.Text
  // Listing details — populated by the Airbnb crawler.
  description   String?   @db.Text
  bedrooms      Int?
  bathrooms     Float?
  beds          Int?
  maxGuests     Int?
  amenities     Json?
  photos        Json?
  crawledAt     DateTime?
  crawlPayload  Json?
  ownerId       String
  owner         User      @relation("OwnerProperties", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastSyncedAt  DateTime?

  reservations   Reservation[]
  expenses       Expense[]
  advances       Advance[]
  directBookings DirectBooking[]
  ownerPayments  OwnerPayment[]
  companyEntries CompanyExpense[]
  ownerReports   OwnerReport[]

  @@index([ownerId])
}

model Reservation {
  id                String            @id @default(cuid())
  propertyId        String
  property          Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  externalId        String
  source            String            @default("airbnb")
  status            ReservationStatus @default(CONFIRMED)
  guestName         String?
  guestPhone        String?
  guestEmail        String?
  numGuests         Int?
  checkIn           DateTime
  checkOut          DateTime
  nights            Int
  pricePerNight     Float             @default(0)
  totalPrice        Float             @default(0) // gross amount paid by guest
  agencyCommission  Float             @default(0) // PMS fee
  portalCommission  Float             @default(0) // Airbnb / Booking commission
  cleaningFee       Float             @default(0)
  serviceFee        Float             @default(0) // legacy / misc service fee
  taxes             Float             @default(0)
  payout            Float             @default(0) // amount paid to owner
  currency          String            @default("AED")
  notes             String?           @db.Text
  rawSummary        String?           @db.Text
  rawDescription    String?           @db.Text
  detailsFilled     Boolean           @default(false)
  // When true, the booking is in the future / not yet paid. The company
  // dashboard accounts these separately so management can see realized
  // revenue vs pipeline. Owner reports ignore this flag.
  upcoming          Boolean           @default(false)
  // Whether the guest has fully paid for this reservation. Extensions
  // (when iCal lengthens an existing stay) carry their own `paid` flag
  // on the ReservationExtension row.
  paid              Boolean           @default(false)
  // Once a reservation is bundled into an owner report it's "closed" and
  // no longer appears in the report builder's pickable list.
  reportId          String?
  report            OwnerReport?      @relation(fields: [reportId], references: [id], onDelete: SetNull)
  // Billing month "YYYY-MM" the row belongs to for monthly reporting.
  // Defaults to the checkIn month; admins can flip the form's
  // "Next month" checkbox to roll the row into the following month.
  monthKey          String?           @db.VarChar(7)
  syncedAt          DateTime          @default(now())
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  extensions        ReservationExtension[]

  @@unique([propertyId, externalId])
  @@index([propertyId])
  @@index([checkIn])
  @@index([checkOut])
  @@index([reportId])
  @@index([monthKey])
  @@index([paid])
}

// Stay extensions captured from iCal — when Airbnb pushes a longer
// checkOut for a reservation we already track, we leave the original
// reservation alone and record the extra nights here so reports keep
// the original window separate from the add-on. Admins fill in
// price / commissions / paid flag the same way as a reservation.
model ReservationExtension {
  id               String      @id @default(cuid())
  reservationId    String
  reservation      Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  // The added window. checkIn typically equals the previous checkOut.
  checkIn          DateTime
  checkOut         DateTime
  nights           Int
  totalPrice       Float       @default(0)
  agencyCommission Float       @default(0)
  portalCommission Float       @default(0)
  payout           Float       @default(0)
  currency         String      @default("AED")
  notes            String?     @db.Text
  paid             Boolean     @default(false)
  // Billing month — admins flip this to the next month if the extension
  // hasn't been paid by the time the original reservation's owner
  // report is generated.
  monthKey         String?     @db.VarChar(7)
  detailsFilled    Boolean     @default(false)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([reservationId])
  @@index([monthKey])
  @@index([paid])
}

enum ExpenseType {
  DEWA
  CHILLER
  DU
  GAS
  CLEANING
  DTCM
  SERVICE_CHARGE
  OTHERS
}

model Expense {
  id          String      @id @default(cuid())
  propertyId  String
  property    Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  date        DateTime
  type        ExpenseType
  description String      @db.Text
  amount      Float       // positive — represented as a deduction in reports
  reportId    String?
  report      OwnerReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)
  // Billing month "YYYY-MM" the expense belongs to. Defaults to the
  // expense date's month; admins can flip "Next month" in the form.
  monthKey    String?     @db.VarChar(7)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([propertyId])
  @@index([date])
  @@index([reportId])
  @@index([monthKey])
}

model Advance {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  date        DateTime
  concept     String   // e.g. "Payment for Rental"
  amount      Float    // positive — represented as a deduction in reports
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([propertyId])
  @@index([date])
}

// Direct bookings come from the public site. Kept separate from `Reservation`
// (which is populated by the Airbnb iCal sync) so the two channels don't
// pollute each other. The Strapi payment flow writes here on success.
model DirectBooking {
  id              String              @id @default(cuid())
  propertyId      String
  property        Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  guestName       String
  guestEmail      String
  guestPhone      String?
  numGuests       Int
  checkIn         DateTime
  checkOut        DateTime
  nights          Int
  pricePerNight   Float               @default(0)
  cleaningFee     Float               @default(0)
  totalPrice      Float               @default(0)
  currency        String              @default("AED")
  status          DirectBookingStatus @default(PENDING)
  // Payment integration — populated by Strapi callback / webhook.
  paymentRef      String?
  paymentProvider String?
  paidAt          DateTime?
  paidAmount      Float?
  notes           String?             @db.Text
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([propertyId])
  @@index([checkIn])
  @@index([status])
}

enum CompanyTransactionKind {
  EXPENSE
  PROFIT
  // DEPOSIT entries are pure log rows — they don't feed dashboard / report
  // totals. Each can later be marked refunded, at which point
  // `refundedAt` / `refundedAmount` are populated.
  DEPOSIT
}

// CompanyExpense holds expense, per-property profit, and per-property
// deposit log entries — the `kind` discriminator picks between them.
// PROFIT/DEPOSIT entries reference a property; EXPENSE entries use a
// category. They share a date+amount shape so the dashboard can net them.
model CompanyExpense {
  id              String                  @id @default(cuid())
  kind            CompanyTransactionKind  @default(EXPENSE)
  // EXPENSE only — null for PROFIT/DEPOSIT entries
  category        CompanyExpenseCategory?
  // PROFIT/DEPOSIT only — null for EXPENSE entries
  propertyId      String?
  property        Property?               @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  date            DateTime
  description     String                  @db.Text
  amount          Float
  // DEPOSIT-only refund metadata. When refundedAt is null the deposit is
  // still held; populated values mean the company has paid it back.
  refundedAt      DateTime?
  refundedAmount  Float?
  // Billing month "YYYY-MM" — used for monthly company-finance reports.
  // Same convention as Reservation/Expense: defaults to the entry date,
  // bumped by one month when the form's "Next month" checkbox is on.
  monthKey        String?                 @db.VarChar(7)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([date])
  @@index([kind])
  @@index([propertyId])
  @@index([monthKey])
}

// A curated bundle of one property's reservations + expenses, prepared by
// admin for an owner. Once an item belongs to a report it's "closed" and
// no longer offered when building future reports.
model OwnerReport {
  id            String   @id @default(cuid())
  ownerId       String
  owner         User     @relation("OwnerReportRecipient", fields: [ownerId], references: [id], onDelete: Cascade)
  propertyId    String
  property      Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name          String   // e.g. "March 2026"
  notes         String?  @db.Text
  // Snapshots of the totals at creation time — kept on the row so the
  // report stays stable even if items are later edited.
  totalIncome   Float    @default(0)
  totalExpenses Float    @default(0)
  netPayout     Float    @default(0)
  createdById   String?
  createdBy     User?    @relation("OwnerReportCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reservations  Reservation[]
  expenses      Expense[]

  @@index([ownerId])
  @@index([propertyId])
}

// Cash settlements paid to an owner. The dashboard sums these as
// "Owners amount" — i.e. how much the company has actually disbursed,
// not the accrued reservation `payout` figure. recordedById tracks who
// entered the row so management has an audit trail.
model OwnerPayment {
  id           String    @id @default(cuid())
  ownerId      String
  owner        User      @relation("OwnerPaymentRecipient", fields: [ownerId], references: [id], onDelete: Cascade)
  // Optional: which property the payout covers. Helps admins reconcile
  // when an owner has multiple properties. Null means the payment is
  // owner-wide (legacy / cross-property settlement).
  propertyId   String?
  property     Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  date         DateTime
  amount       Float
  method       String?   // bank, cash, transfer, …
  reference    String?   // invoice / period / external ref
  notes        String?   @db.Text
  // Explicit billing month (YYYY-MM) — selected by the admin so reports
  // attribute the payout to the period it settles, separate from the
  // cash-out date stored above.
  monthKey     String?   @db.VarChar(7)
  recordedById String?
  recordedBy   User?     @relation("OwnerPaymentRecorder", fields: [recordedById], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([ownerId])
  @@index([propertyId])
  @@index([date])
  @@index([monthKey])
}

// Push-notification device tokens for the owner mobile app. One owner
// can have several devices; the same Expo push token never repeats so
// it's the unique key — re-registrations bump `updatedAt`.
model OwnerDevice {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String?  // ios / android (best-effort, app reports it)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model AppSettings {
  id          Int      @id @default(1)
  brandName   String   @default("Badam Owners")
  legalName   String   @default("Badam Holiday Homes")
  tagline     String   @default("Curated short-term rentals across Dubai.")
  logoUrl     String?  @db.Text
  faviconUrl  String?  @db.Text
  email       String?
  phone       String?
  whatsapp    String?
  website     String?  @db.Text
  address     String?  @db.Text
  city        String?
  country     String?
  instagram   String?  @db.Text
  facebook    String?  @db.Text
  linkedin    String?  @db.Text
  tiktok      String?  @db.Text
  youtube     String?  @db.Text
  bookingUrl  String?  @db.Text
  ownerPortal String?  @db.Text
  about       String?  @db.Text
  currency    String   @default("AED")
  timezone    String   @default("Asia/Dubai")
  updatedAt   DateTime @updatedAt
}
