# Force npm to include optional dependencies even if the host (e.g. Hostinger
# auto-deploy) defaults to `--omit=optional`. Native platform-specific
# binaries like @parcel/watcher-linux-x64-glibc and @next/swc-linux-* are
# distributed as optionalDependencies — without them Next.js can't load its
# config or build. `include=optional` overrides the omit list.
include=optional
