# Force pnpm to use a flat node_modules layout (npm-style) so packages can
# resolve deps that were declared under an alias by their original name.
#
# `node-ical` declares its temporal polyfill via an alias and then runtime-
# requires `temporal-polyfill` directly. pnpm's strict isolated layout puts
# the alias under @js-temporal/polyfill but no `temporal-polyfill/` dir, so
# the require fails on prod. `node-linker=hoisted` makes pnpm behave like npm
# install (flat tree) which lets the require succeed.
#
# Plus shamefully-hoist=true exposes transitive deps at the top level for the
# few packages that ignore proper resolution.
node-linker=hoisted
shamefully-hoist=true
